# Entropy — Production Environment Variables
# Copy this to .env and fill in your values before running docker compose.
#
# NEVER commit .env to git. It is already in .gitignore.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Use a long randomly generated password.
# Example: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
DB_PASSWORD=CHANGE_ME_generate_a_strong_password_here

# Derived — do not change the format, just change DB_PASSWORD above
# If running docker-compose directly from this file, DATABASE_URL is set
# per-service in docker-compose.aws.yml using ${DB_PASSWORD} directly.

# ── Redis ─────────────────────────────────────────────────────────────────────
# Default: no password on Redis (it is bound to 127.0.0.1 inside Docker only)
# If you want Redis auth, add requirepass to the redis command in docker-compose.
REDIS_URL=redis://redis:6379

# ── Application ──────────────────────────────────────────────────────────────
ENVIRONMENT=production

# ── Optional: Sentry error tracking ──────────────────────────────────────────
# Leave blank to disable. Get a DSN at sentry.io (free for 5k errors/month).
SENTRY_DSN=
